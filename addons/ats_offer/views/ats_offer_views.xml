<odoo>
    <record id="view_ats_offer_form" model="ir.ui.view">
        <field name="name">ats.offer.form</field>
        <field name="model">ats.offer</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Job Offer">
                <group>
                    <field name="name"/>
                    <field name="applicant_id"/>
                    <field name="position_title"/>
                    <field name="salary"/>
                    <field name="currency_id"/>
                    <field name="offer_letter_url"/>
                    <field name="status"/>
                    <field name="sent_at"/>
                    <field name="accepted_at"/>
                    <field name="rejected_at"/>
                    <field name="notes"/>
                </group>
            </form>
        </field>
    </record>

    <record id="view_ats_offer_tree" model="ir.ui.view">
        <field name="name">ats.offer.list</field>
        <field name="model">ats.offer</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="position_title"/>
                <field name="salary"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_ats_offer" model="ir.actions.act_window">
        <field name="name">Offers</field>
        <field name="res_model">ats.offer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ats_offer_root" name="ATS Offers"/>
    <menuitem id="menu_ats_offer" name="Job Offers" parent="menu_ats_offer_root" action="action_ats_offer"/>
</odoo>